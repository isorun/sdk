{
  "name": "isorun",
  "version": "1.0.1",
  "description": "TypeScript SDK for Isorun — isolated Linux VM sandboxes for running untrusted and AI-generated code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./claude-agents/orchestrator": {
      "types": "./dist/claude-agents/orchestrator.d.ts",
      "import": "./dist/claude-agents/orchestrator.js"
    },
    "./claude-agents/runner": {
      "types": "./dist/claude-agents/runner.d.ts",
      "import": "./dist/claude-agents/runner.js"
    },
    "./openai-agents": {
      "types": "./dist/openai-agents.d.ts",
      "import": "./dist/openai-agents.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "bin": {
    "isorun-mcp": "dist/mcp-cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "isorun",
    "sandbox",
    "code-execution",
    "code-interpreter",
    "isolation",
    "ai-agent",
    "claude",
    "claude-managed-agents"
  ],
  "license": "MIT",
  "author": "Isorun <hello@isorun.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isorun/sdk.git"
  },
  "homepage": "https://isorun.ai",
  "engines": {
    "node": ">=22.19.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@langchain/core": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@openai/agents": "^0.11.0",
    "zod": ">=3.23 <5"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "undici": "8.3.0"
  },
  "optionalDependencies": {
    "@isorun/http-transport-linux-x64-gnu": "^0.8.8",
    "@isorun/http-transport-linux-arm64-gnu": "^0.8.8",
    "@isorun/http-transport-linux-x64-musl": "^0.8.8",
    "@isorun/http-transport-linux-arm64-musl": "^0.8.8",
    "@isorun/http-transport-darwin-arm64": "^0.8.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@langchain/core": "^1.1.48",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.11.5",
    "@types/node": ">=18",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "provenance": true
  }
}
